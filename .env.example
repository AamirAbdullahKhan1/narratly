# Neon PostgreSQL Database Connection
# Get this from your Neon project dashboard
NEON_DB_URL=postgresql://user:password@ep-xxx.us-east-1.neon.tech/dbname

# Ollama Local LLM Configuration
# Make sure Ollama is running on localhost:11434
# Download from: https://ollama.ai
OLLAMA_BASE_URL=http://localhost:11434

# Optional: Specify which model to use (default: mistral)
# Available models: mistral, llama2, neural-chat, etc.
# OLLAMA_MODEL=mistral
